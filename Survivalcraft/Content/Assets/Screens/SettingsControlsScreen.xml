<Screen xmlns="runtime-namespace:Game">

  <PanoramaWidget />

  <StackPanelWidget Direction="Horizontal">

    <CanvasWidget Style="{Widgets/TopBarContents}" >
      <LabelWidget Name="TopBar.Label" Text="[SettingsControlsScreen:0]" />
    </CanvasWidget>

    <CanvasWidget Margin="10, 20">
      <BevelledRectangleWidget Style="{Styles/Area}" />
      <ScrollPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3, 3">
        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:16]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="MemoryBankStyle" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:15]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="AllowInitialIntro" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:1]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="MoveControlMode" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:2]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="LookControlMode" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:3]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="LeftHandedLayout" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:4]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="FlipVerticalAxis" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:5]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="AutoJump" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Name="HorizontalCreativeFlightPanel" Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:6]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="HorizontalCreativeFlight" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Name="CreativeDragMaxStackingPanel" Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:17]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="CreativeDragMaxStacking" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Name="SplitDragHalfPanel" Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:18]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="SplitDragHalf" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:26]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="ShortInventoryLooping" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:7]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="MoveSensitivitySlider" Granularity="0.05" MinValue="0" MaxValue="1" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:8]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="LookSensitivitySlider" Granularity="0.05" MinValue="0" MaxValue="1" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:9]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="GamepadCursorSpeedSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0.3" MaxValue="1.7" Granularity="0.1" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:10]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
