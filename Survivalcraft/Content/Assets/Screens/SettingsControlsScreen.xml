          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:25]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="GamepadTriggerThresholdSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0.1" MaxValue="1" Granularity="0.1" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:11]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="CreativeDigTimeSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0.1" MaxValue="1" Granularity="0.01" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:12]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="CreativeReachSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="5" MaxValue="10" Granularity="0.5" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:13]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="HoldDurationSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0.15" MaxValue="0.7" Granularity="0.05" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:14]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="DragDistanceSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="4" MaxValue="16" Granularity="1" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:20]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="MoveWidgetMarginXSlider" Granularity="0.01" MinValue="0" MaxValue="0.3" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:21]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="MoveWidgetMarginYSlider" Granularity="0.01" MinValue="0" MaxValue="0.3" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:27]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="KeyboardMappingEntry" Text ="[SettingsControlsScreen:22]" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:28]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="GamepadMappingEntry" Text ="[SettingsControlsScreen:22]" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsControlsScreen:23]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <BevelledButtonWidget Name="CameraManageEntry" Text ="[SettingsControlsScreen:24]" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
          </UniformSpacingPanelWidget>

        </StackPanelWidget>
      </ScrollPanelWidget>
    </CanvasWidget>

  </StackPanelWidget>

</Screen>