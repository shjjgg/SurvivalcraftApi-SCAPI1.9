<Screen xmlns="runtime-namespace:Game">

	<PanoramaWidget />

	<StackPanelWidget Direction="Horizontal">

		<CanvasWidget Style="{Widgets/TopBarContents}" >
			<LabelWidget Name="TopBar.Label" Text="[SettingsUiScreen:0]" />
		</CanvasWidget>

		<CanvasWidget Margin="10, 20">
      <BevelledRectangleWidget Style="{Styles/Area}" />
			<ScrollPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3, 3">
				<StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:1]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="LanguageButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:10]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="DisplayLogButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Name="WindowModeContainer" Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:2]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="WindowModeButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:3]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<SliderWidget Name="UIScaleSlider" Size="Infinity, 60" VerticalAlignment="Center" Granularity="0.05" MinValue="0.5" MaxValue="1.2" Margin="20, 0"/>
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:4]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="UpsideDownButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Name="AdaptEdgeToEdgeDisplayContainer" Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:16]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="AdaptEdgeToEdgeDisplay" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:5]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="HideMoveLookPads" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:13]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="HideCrosshair" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:6]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="ShowGuiInScreenshotsButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:7]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="ShowLogoInScreenshotsButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:8]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="ScreenshotSizeButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Name="ScreenshotSizeCustomWidthSliderContainer" Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsUiScreen:14]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="ScreenshotSizeCustomWidthSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0" MaxValue="17" Granularity="1" />
          </UniformSpacingPanelWidget>

          <UniformSpacingPanelWidget Name="ScreenshotSizeCustomAspectRatioSliderContainer" Direction="Horizontal" Margin="0, 3">
            <LabelWidget Text="[SettingsUiScreen:15]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
            <SliderWidget Name="ScreenshotSizeCustomAspectRatioSlider" Size="Infinity, 60" VerticalAlignment="Center" Margin="20, 0" MinValue="0" MaxValue="9" Granularity="1" />
          </UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:9]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="CommunityContentModeButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:12]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="OriginalCommunityContentModeButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

					<UniformSpacingPanelWidget Direction="Horizontal" Margin="0, 3">
						<LabelWidget Text="[SettingsUiScreen:11]" HorizontalAlignment="Far" VerticalAlignment="Center" Margin="20, 0" />
						<BevelledButtonWidget Name="DeleteWorldNeedToTextButton" Style="{Styles/ButtonStyle_310x60}" VerticalAlignment="Center" Margin="20, 0" />
					</UniformSpacingPanelWidget>

				</StackPanelWidget>
			</ScrollPanelWidget>
		</CanvasWidget>

	</StackPanelWidget>

</Screen>