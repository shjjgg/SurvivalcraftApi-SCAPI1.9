<Screen xmlns="runtime-namespace:Game">

  <PanoramaWidget />

  <StackPanelWidget Direction="Horizontal">

    <CanvasWidget Style="{Widgets/TopBarContents}" >
      <LabelWidget Name="TopBar.Label" Text="[CommunityContentScreen:1]" />
    </CanvasWidget>

    <StackPanelWidget Direction="Vertical" VerticalAlignment="Center">

      <CanvasWidget Size="0, 8" />

      <StackPanelWidget Direction="Horizontal">
        <StackPanelWidget Margin="10, 0">
          <LabelWidget Name="Order" Text="[CommunityContentScreen:2]" VerticalAlignment="Center" ClampToBounds="true"/>
          <CanvasWidget Size="10, 0"/>
          <BevelledButtonWidget Name="ChangeOrder" Text="[CommunityContentScreen:3]" Style="{Styles/ButtonStyle_70x60}" VerticalAlignment="Center"/>
        </StackPanelWidget>
          <StackPanelWidget Margin="10, 0">
              <LabelWidget Name="Filter" Text="[CommunityContentScreen:4]" VerticalAlignment="Center"/>
              <CanvasWidget Size="10, 0"/>
              <BevelledButtonWidget Name="ChangeFilter" Text="[CommunityContentScreen:5]" Style="{Styles/ButtonStyle_70x60}" VerticalAlignment="Center"/>
          </StackPanelWidget>
        <StackPanelWidget Direction="Horizontal" Margin="10, 0">
          <CanvasWidget VerticalAlignment="Center" Size="Infinity, 50" Margin="0, 5" >
            <BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
            <LabelWidget HorizontalAlignment="Center" VerticalAlignment="Center" Name="placeholder" Text="[CommunityContentScreen:9]" Color="96, 96, 96"/>
            <TextBoxWidget Size="Infinity, 60" Name="key" VerticalAlignment="Center" Margin="10,0"/>
            <LinkWidget Name="ClearSearchLink" Text="[OriginalCommunityContentScreen:7]" Color="64, 192, 64" HorizontalAlignment="Far" VerticalAlignment="Center" DropShadow="true" Margin="10, 0" />
          </CanvasWidget>
          <CanvasWidget Size="5, 0"/>
          <BevelledButtonWidget Name="Search" Text="[CommunityContentScreen:10]" Style="{Styles/ButtonStyle_115x60}" VerticalAlignment="Center"/>
          <BevelledButtonWidget Name="SearchType" Text="[CommunityContentScreen:10]" Size="115, 60" VerticalAlignment="Center"/>
        </StackPanelWidget>
      </StackPanelWidget>

      <CanvasWidget Size="0, 8" />

      <CanvasWidget Margin="10, 0">
        <BevelledRectangleWidget Style="{Styles/Area}" />
        <TreeViewWidget Name="Tree" Direction="Vertical" Margin="3, 3" />
      </CanvasWidget>

      <CanvasWidget Size="0, 8" />

      <StackPanelWidget Direction="Horizontal" Margin="5, 0">
        <BevelledButtonWidget Name="Download" Size="230,60" Text="[CommunityContentScreen:6]"/>
        <CanvasWidget Size="Infinity, 0"/>
        <BevelledButtonWidget Name="Action" Style="{Styles/ButtonStyle_160x60}" Text="[CommunityContentScreen:11]"/>
        <CanvasWidget Size="10, 0"/>
        <BevelledButtonWidget Name="Action2" Style="{Styles/ButtonStyle_160x60}" Text="[CommunityContentScreen:7]"/>
        <CanvasWidget Size="10, 0"/>
        <BevelledButtonWidget Name="WebPage" Style="{Styles/ButtonStyle_160x60}" Text="[CommunityContentScreen:12]"/>
        <CanvasWidget Size="10, 0"/>
        <BevelledButtonWidget Name="Login" Style="{Styles/ButtonStyle_160x60}" Text="[CommunityContentScreen:13]"/>
      </StackPanelWidget>

      <CanvasWidget Size="0, 5" />

    </StackPanelWidget>
    
  </StackPanelWidget>

</Screen>