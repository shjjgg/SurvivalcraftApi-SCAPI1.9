<Screen xmlns="runtime-namespace:Game">
  <PanoramaWidget />
  <StackPanelWidget Direction="Horizontal">
    <CanvasWidget Style="{Widgets/TopBarContents}" >
      <LabelWidget Name="TopBar.Label" Text="[ManageClassSubstitutesScreen:1]" />
    </CanvasWidget>
    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center">
      <StackPanelWidget Direction="Vertical" Margin="10, 10">
        <CanvasWidget>
          <BevelledRectangleWidget Style="{Styles/Area}" />
          <ScrollPanelWidget Name="Scroll" Direction="Vertical" Margin="3, 3" />
        </CanvasWidget>
      </StackPanelWidget>
    </StackPanelWidget>
  </StackPanelWidget>
</Screen>